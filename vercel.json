{
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "fivestardatarecovery.com" }],
      "destination": "https://www.fivestardatarecovery.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/((?!_nuxt|favicon|.*\\.(?:js|css|png|jpg|jpeg|webp|svg|ico|woff2?|ttf|gif|mp4|json)).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/_nuxt/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
